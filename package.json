{
  "name": "@ntsim/oxlint-config",
  "version": "0.3.0",
  "description": "Personal oxlint configuration",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --report-unused-disable-directives --deny-warnings",
    "lint:fix": "oxlint --fix --report-unused-disable-directives --deny-warnings",
    "types": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-jest-dom": {
      "optional": true
    },
    "eslint-plugin-testing-library": {
      "optional": true
    },
    "oxlint-tsgolint": {
      "optional": true
    }
  },
  "lint-staged": {
    "*": [
      "oxfmt --no-error-on-unmatched-pattern"
    ],
    "*.{ts,tsx,js,jsx}": [
      "oxlint --report-unused-disable-directives --deny-warnings"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.0.9+sha512.34ce82e6780233cf9cad8685029a8f81d2e06196c5a9bad98879f7424940c6817c4e4524fb7d38b8553ceed48b9758b8ebaf1abd3600c232c4c8cf7366086f38"
}
